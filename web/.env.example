# Backend API (REST). Em dev, Next rewrites /api/backend -> este URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Opcional: GraphQL endpoint absoluto (SSR). Se vazio, usa NEXT_PUBLIC_API_URL + /graphql
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql

# Mapbox (opcional). Se quiseres usar Mapbox GL em vez de Leaflet/OSM, descomenta:
# NEXT_PUBLIC_MAPBOX_TOKEN=pk....
